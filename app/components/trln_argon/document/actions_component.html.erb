<%= content_tag @tag, class: @classes do %>
  <%= trln_actions.present? %>
  <% actions.each do |action| %>
    <%= action.is_a?(TrlnArgon::Document::ActionComponent) %>
    <% if @wrapping_tag %>
      <%= content_tag(@wrapping_tag, class: Array(@wrapping_classes) + [action.key]) do %>
         <%= action %>
      <% end %>
    <% else %>
      <%= action %>
    <% end %>
  <% end %>
<% end %>
